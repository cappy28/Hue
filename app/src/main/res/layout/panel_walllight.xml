<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView android:text="🎨 Multicolor Wall Light"
        android:textColor="#FF6B35" android:textStyle="bold" android:textSize="16sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/wlOn" android:text="☀️ ON" android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="#FFD700"/>
        <Button android:id="@+id/wlOff" android:text="🌙 OFF" android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1" android:backgroundTint="#222244"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/wlBrightP" android:text="☀️+" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="#555577"/>
        <Button android:id="@+id/wlBrightM" android:text="☀️-" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#555577"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/wlRed" android:text="🔴" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF0000"/>
        <Button android:id="@+id/wlGreen" android:text="🟢" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#00CC00"/>
        <Button android:id="@+id/wlBlue" android:text="🔵" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#0044FF"/>
        <Button android:id="@+id/wlWhite" android:text="⚪" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#DDDDDD"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/wlOrange" android:text="🟠" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF6400"/>
        <Button android:id="@+id/wlLime" android:text="🟡" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#AAFF00"/>
        <Button android:id="@+id/wlCyan" android:text="🩵" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#00FFFF"/>
        <Button android:id="@+id/wlPink" android:text="🩷" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF0096"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/wlFlash" android:text="⚡" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/wlStrobe" android:text="🔦" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/wlFade" android:text="🌅" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/wlSmooth" android:text="🌊" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/wlSpeedP" android:text="⏩+" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/wlSpeedM" android:text="⏩-" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/wlMusic1" android:text="🎵 M1" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#9C27B0"/>
        <Button android:id="@+id/wlMusic2" android:text="🎵 M2" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#9C27B0"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/wlMusic3" android:text="🎵 M3" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#9C27B0"/>
        <Button android:id="@+id/wlMusic4" android:text="🎵 M4" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#9C27B0"/>
    </LinearLayout>
</LinearLayout>
