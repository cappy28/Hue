<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView android:text="🔲 Baltimore Panel Light"
        android:textColor="#FF6B35" android:textStyle="bold" android:textSize="16sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="💡 Maintiens appuyé un bouton pour le programmer avec le scanner IR"
        android:textColor="#AAAAAA" android:textSize="11sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>

    <!-- Scanner IR -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">
        <Button android:id="@+id/balScan" android:text="🔍 Scanner IR"
            android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
            android:layout_marginEnd="4dp" android:backgroundTint="#FF6B35"/>
        <Button android:id="@+id/balScanStop" android:text="✅ Code trouvé !"
            android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
            android:backgroundTint="#4CAF50"/>
    </LinearLayout>

    <!-- ON OFF -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balOn" android:text="☀️ ON"
            android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
            android:layout_marginEnd="4dp" android:backgroundTint="#FFD700"/>
        <Button android:id="@+id/balOff" android:text="🌙 OFF"
            android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
            android:backgroundTint="#222244"/>
    </LinearLayout>

    <!-- Luminosité -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balBrightP" android:text="☀️ +"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:layout_marginEnd="4dp" android:backgroundTint="#555577"/>
        <Button android:id="@+id/balBrightM" android:text="☀️ -"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#555577"/>
    </LinearLayout>

    <!-- Couleurs ligne 1 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/balRed" android:text="🔴"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FF0000"/>
        <Button android:id="@+id/balGreen" android:text="🟢"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#00CC00"/>
        <Button android:id="@+id/balBlue" android:text="🔵"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#0044FF"/>
        <Button android:id="@+id/balWhite" android:text="⚪"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#DDDDDD"/>
    </LinearLayout>

    <!-- Couleurs ligne 2 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balOrange" android:text="🟠"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FF6400"/>
        <Button android:id="@+id/balLime" android:text="🟡"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#AAFF00"/>
        <Button android:id="@+id/balCyan" android:text="🩵"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#00FFFF"/>
        <Button android:id="@+id/balWarmW" android:text="🕯️"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FF8C42"/>
    </LinearLayout>

    <!-- Couleurs ligne 3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balPink" android:text="🩷"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FF0096"/>
        <Button android:id="@+id/balPurple" android:text="🟣"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#7700FF"/>
        <Button android:id="@+id/balYellow" android:text="🟡"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FFCC00"/>
        <Button android:id="@+id/balWarmW2" android:text="🌡️ WW"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#FF8C42"/>
    </LinearLayout>

    <!-- Modes et vitesse -->
    <TextView android:text="✨ Modes" android:textColor="#CCCCCC"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/balMode" android:text="🔄 Mode"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balNight" android:text="🌙 Nuit"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balSpeedP" android:text="⏩ +"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balSpeedM" android:text="⏩ -"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
    </LinearLayout>

    <!-- Effets -->
    <TextView android:text="✨ Effets" android:textColor="#CCCCCC"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/balFlash" android:text="⚡ Flash"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balStrobe" android:text="🔦 Strobe"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balFade" android:text="🌅 Fade"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balSmooth" android:text="🌊 Smooth"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
    </LinearLayout>

    <!-- Musique -->
    <TextView android:text="🎵 Sync Musique" android:textColor="#CCCCCC"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/balMusic1" android:text="🎵 M1"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#9C27B0"/>
        <Button android:id="@+id/balMusic2" android:text="🎵 M2"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#9C27B0"/>
        <Button android:id="@+id/balMusic3" android:text="🎵 M3"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#9C27B0"/>
        <Button android:id="@+id/balMusic4" android:text="🎵 M4"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#9C27B0"/>
    </LinearLayout>

    <!-- Timers -->
    <TextView android:text="⏱️ Timers" android:textColor="#CCCCCC"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balTimer1" android:text="1H"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balTimer2" android:text="2H"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balTimer3" android:text="3H"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
        <Button android:id="@+id/balTimer4" android:text="4H"
            android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
            android:backgroundTint="#334"/>
    </LinearLayout>

</LinearLayout>
