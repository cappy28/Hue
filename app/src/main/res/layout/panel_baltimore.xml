<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView android:text="🔲 Baltimore Panel Light"
        android:textColor="#FF6B35" android:textStyle="bold" android:textSize="16sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balOn" android:text="☀️ ON" android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="#FFD700"/>
        <Button android:id="@+id/balOff" android:text="🌙 OFF" android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1" android:backgroundTint="#222244"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balBrightP" android:text="☀️+" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="#555577"/>
        <Button android:id="@+id/balBrightM" android:text="☀️-" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#555577"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/balRed" android:text="🔴" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF0000"/>
        <Button android:id="@+id/balGreen" android:text="🟢" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#00CC00"/>
        <Button android:id="@+id/balBlue" android:text="🔵" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#0044FF"/>
        <Button android:id="@+id/balWhite" android:text="⚪" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#DDDDDD"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balOrange" android:text="🟠" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF6400"/>
        <Button android:id="@+id/balLime" android:text="🟡" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#AAFF00"/>
        <Button android:id="@+id/balCyan" android:text="🩵" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#00FFFF"/>
        <Button android:id="@+id/balWarmW" android:text="🕯️" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FF8C42"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
        <Button android:id="@+id/balMode" android:text="🔄 Mode" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/balNight" android:text="🌙 Nuit" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/balSpeedP" android:text="⏩+" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
        <Button android:id="@+id/balSpeedM" android:text="⏩-" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#334"/>
    </LinearLayout>
</LinearLayout>
